{
  "name": "static-mcpify",
  "version": "1.0.1",
  "type": "module",
  "description": "Turn any structured content into a static MCP (Model Context Protocol) server",
  "main": "dist/src/server/index.js",
  "exports": {
    ".": "./dist/src/server/index.js",
    "./server": "./dist/src/server/index.js",
    "./handler": "./dist/src/server/handler.js",
    "./web-handler": "./dist/src/server/web-handler.js"
  },
  "bin": {
    "smcp": "./dist/src/cli/index.js"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.js.map",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "contentful",
    "cms",
    "static",
    "ai",
    "llm",
    "tools"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/megazear7/static-mcpify.git"
  },
  "scripts": {
    "build:ts": "tsc",
    "prepublishOnly": "npm run build:ts"
  },
  "dependencies": {
    "@contentful/rich-text-html-renderer": "^17.1.6",
    "@contentful/rich-text-types": "^17.2.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "contentful": "^11.10.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "inquirer": "^12.11.1",
    "node-html-markdown": "^2.0.0",
    "slugify": "^1.6.6",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
