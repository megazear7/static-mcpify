{
  "private": true,
  "workspaces": ["module", "netlify"],
  "scripts": {
    "build:ts": "npm run build:ts -w module",
    "build:contentful": "tsx module/src/cli/index.ts build --output examples/contentful",
    "build": "npm run build:ts && npm run build:contentful",
    "start": "npm run build:ts && concurrently --names static,contentful,brand \"BASE_URL=http://localhost:3102 tsx module/src/server/standalone.ts examples/static/content 3100\" \"tsx module/src/server/standalone.ts examples/contentful/content 3101\" \"npx serve netlify/brand -l 3102\"",
    "test": "tsx test/sanity.ts",
    "fix": "eslint --fix 'module/src/**/*.ts' 'netlify/functions/**/*.ts' 'test/**/*.ts'",
    "lint": "eslint 'module/src/**/*.ts' 'netlify/functions/**/*.ts' 'test/**/*.ts'"
  },
  "devDependencies": {
    "@netlify/functions": "^5.1.2",
    "@types/express": "^5.0.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "serve": "^14.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
